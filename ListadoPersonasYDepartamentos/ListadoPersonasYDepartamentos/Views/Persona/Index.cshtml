@model IEnumerable<Domain.DTOs.PersonaConNombreDeDepartamentoDTO>

@{
    ViewData["Title"] = "View";
}

<h1>Listado de Personas</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Crear Persona</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Nombre
            </th>
            <th>  
                Apellidos
            </th>
            <th>
                Fecha de nacimiento
            </th>
            <th>
                Nombre Departamento
            </th>
            <th>
                Imagen
            </th>
            <th>
                Acciones
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.nombre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.apellido)
                </td>
                <td>
                    <p>@item.fechaNac.ToShortDateString()</p>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.nombreDepartamento)
                </td>
                <td>
                    <img src="@item.imagen" alt="Imagen de @item.nombre" width="100" height="100" />
                </td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.id }) |
                    @Html.ActionLink("Details", "Details", new { id = item.id }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.id })
                </td>
            </tr>
        }
    </tbody>
</table>